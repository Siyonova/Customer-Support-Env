# Copy this file to .env and fill in your values
# Then run: source .env

# The OpenAI-compatible API endpoint for your HuggingFace model
# Format: https://api-inference.huggingface.co/models/<org>/<model>/v1
API_BASE_URL=https://api-inference.huggingface.co/models/mistralai/Mistral-7B-Instruct-v0.3/v1

# The model identifier (must match the model in API_BASE_URL)
MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.3

# Your HuggingFace API token
# Get one at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here
