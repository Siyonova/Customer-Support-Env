# Copy this to .env and fill in HF_TOKEN.
# The script loads this automatically — no "export" needed.

# Generic HuggingFace Router (works with any supported model)
API_BASE_URL=https://router.huggingface.co/v1

# Free model with tool/function calling support
# DO NOT change to meta-llama/Llama-2-7b-chat-hf — that requires a Pro subscription
MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.3

# Your HuggingFace API token (read access is enough)
# Get one at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here
