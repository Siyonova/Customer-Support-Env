# Copy this file to .env and fill in your values.
# The inference script loads this automatically — no "export" needed.

# HuggingFace Router API (new URL — api-inference.huggingface.co is no longer supported)
API_BASE_URL=https://router.huggingface.co/hf-inference/models/mistralai/Mistral-7B-Instruct-v0.3/v1

# The model identifier
MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.3

# Your HuggingFace API token
# Get one at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here
